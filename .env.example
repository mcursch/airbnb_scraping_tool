# ── API keys ──────────────────────────────────────────────────────────────────

# Required for the extraction stage (Stage 3).
# Obtain at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: paid scraping-API fallback key (ScraperAPI, Apify, etc.).
# Leave empty to disable the fallback provider.
SCRAPER_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────

# SQLAlchemy database URL.  Defaults to a local SQLite file (scanner.db).
# Swap to PostgreSQL later without any code changes:
#   DATABASE_URL=postgresql+psycopg2://user:pass@localhost/scanner
DATABASE_URL=sqlite:///./scanner.db

# ── Scraper tunables ──────────────────────────────────────────────────────────

# Maximum pages fetched per source per search run.
SCRAPER_PAGE_LIMIT=5

# Randomised delay range between requests (seconds).  Keep these polite.
SCRAPER_REQUEST_DELAY_MIN=1.5
SCRAPER_REQUEST_DELAY_MAX=4.0

# Set to false to watch Playwright operate (useful for debugging).
SCRAPER_HEADLESS=true

# ── Extraction tunables ───────────────────────────────────────────────────────

# Number of pending raw scrapes above which the Batches API path is used
# (50 % cheaper, ~1 h turnaround) instead of real-time extraction.
EXTRACTION_BATCH_THRESHOLD=20

# Anthropic model used for structured extraction.
EXTRACTION_MODEL=claude-opus-4-5
