# Copy this to .env and fill in your values.

# Required for LLM extraction (Stage 3). Not needed for --no-extract runs.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the SQLite path or use a Postgres URL
# DATABASE_URL=sqlite:///./scanner.db
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost/scanner

# Scraper tuning (all have sensible defaults)
# MAX_PAGES=3
# RATE_LIMIT_MIN_SECONDS=2.0
# RATE_LIMIT_MAX_SECONDS=5.0
# BROWSER_HEADLESS=true
# PAGE_LOAD_TIMEOUT_MS=30000

# Optional: paid scraping API key (used by fallback_api.py, Stage 2)
# SCRAPER_API_KEY=
